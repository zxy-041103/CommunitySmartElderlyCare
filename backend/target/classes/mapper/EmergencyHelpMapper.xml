<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.community.elderly.mapper.EmergencyHelpMapper">

    <resultMap id="BaseResultMap" type="com.community.elderly.entity.EmergencyHelp">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="help_type" property="helpType"/>
        <result column="urgency" property="urgency"/>
        <result column="description" property="description"/>
        <result column="phone" property="phone"/>
        <result column="location" property="location"/>
        <result column="help_status" property="helpStatus"/>
        <result column="handler_id" property="handlerId"/>
        <result column="handle_result" property="handleResult"/>
        <result column="handle_time" property="handleTime"/>
        <result column="is_processed" property="isProcessed"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectPageByUserId" resultMap="BaseResultMap">
        SELECT * FROM emergency_help
        WHERE user_id = #{userId}
        ORDER BY create_time DESC
    </select>

    <select id="selectPageByHandlerId" resultMap="BaseResultMap">
        SELECT * FROM emergency_help
        WHERE handler_id = #{handlerId}
        ORDER BY create_time DESC
    </select>

</mapper>
